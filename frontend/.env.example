# ThingsBoard Cloud Connection Configurations
# Copy this file to .env.local and configure your actual credentials.

THINGSBOARD_URL=https://thingsboard.cloud

# Tenant Admin Email (Your GitHub SSO associated email)
THINGSBOARD_USERNAME=your-email@example.com

# ThingsBoard Tenant Password
THINGSBOARD_PASSWORD=your-password

# Optional: Test Device ID (found in ThingsBoard Cloud -> Devices)
THINGSBOARD_DEVICE_ID=
